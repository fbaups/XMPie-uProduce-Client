{
  "name": "arajcany/xmpie-uproduce-client",
  "description": "Simple way to interact with the uProduce WSDL API",
  "type": "project",
  "license": "MIT",
  "require": {
    "ext-json": "*",
    "ext-soap": "*",
    "ext-dom": "*",
    "php": ">=8.2",
    "cakephp/core": "^5.0.1",
    "cakephp/chronos": "^3.0.4",
    "phpoffice/phpspreadsheet": "^2.1",
    "league/csv": "^9.9",
    "fxaps/xmpie-wsdl-wrapper-uproduce": "13.*",
    "arajcany/tool-box": "^2.1",
    "arajcany/pre-press-tricks": "^1.3"
  },
  "require-dev": {
    "phpunit/phpunit": "*",
    "symfony/var-dumper": "^6.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Test\\": "tests/"
    }
  },
  "prefer-stable": true
}
