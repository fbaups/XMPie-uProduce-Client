{
  "name": "arajcany/boilerplate-composer",
  "description": "Clone as a starting point for Projects/Libraries.",
  "type": "project",
  "license": "MIT",
  "require": {
    "ext-json": "*",
    "ext-soap": "*",
    "ext-dom": "*",
    "php": ">=8.0",
    "fxaps/xmpie-wsdl-wrapper-uproduce": "12.*",
    "cakephp/core": "^4.4",
    "cakephp/chronos": "^2.3",
    "phpoffice/phpspreadsheet": "^1.28",
    "league/csv": "^9.9",
    "league/climate": "^3.8",
    "arajcany/tool-box": "^2.1",
    "arajcany/pre-press-tricks": "^1.1"
  },
  "require-dev": {
    "phpunit/phpunit": "*",
    "symfony/var-dumper": "^6.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Test\\": "tests/"
    }
  },
  "prefer-stable": true
}
